<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefWidth="950" prefHeight="700" styleClass="main-bg" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.StudentDashboardController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="ENSCS Student Dashboard" styleClass="title-label"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger" style="-fx-padding: 8 20;" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Browse Internships">
            <VBox spacing="15">
                <padding><Insets top="15" /></padding>
                <TextField fx:id="searchField" promptText="Search by title, company or tag…" />
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <ListView fx:id="offersListView" prefWidth="340" />
                    <VBox fx:id="detailView" spacing="12" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 25;">
                        <Label fx:id="detailTitle" styleClass="title-label" style="-fx-font-size: 22px;" />
                        <Label fx:id="detailCompany" styleClass="subtitle-label" style="-fx-font-size: 15px;" />
                        <Separator />
                        <Label text="Description:" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <Label fx:id="detailDescription" wrapText="true" styleClass="subtitle-label" />
                        <Label text="Requirements:" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <Label fx:id="detailRequirements" wrapText="true" styleClass="subtitle-label" />
                        <Label text="Tags:" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <Label fx:id="detailTags" wrapText="true" style="-fx-text-fill: #3b82f6; -fx-font-style: italic;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="applyButton" onAction="#handleApply" text="Apply Now" maxWidth="Infinity" styleClass="btn-primary" style="-fx-padding: 14;" />
                    </VBox>
                </HBox>
            </VBox>
        </Tab>
        <Tab text="My Applications">
            <VBox spacing="15">
                <padding><Insets top="15" /></padding>
                <TableView fx:id="applicationsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colOfferTitle" prefWidth="420" text="Position" />
                        <TableColumn fx:id="colAppDate" prefWidth="160" text="Date Applied" />
                        <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Refresh Status" onAction="#refreshApplications" styleClass="btn-secondary" style="-fx-padding: 8 20;" />
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>