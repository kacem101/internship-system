<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefWidth="950" prefHeight="700" style="-fx-background-color: #f4f4f4;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.StudentDashboardController">
    
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="ENSCS Student Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Logout" onAction="#handleLogout" 
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        
        <Tab text="Browse Internships">
            <VBox spacing="15">
                <padding><Insets top="15" /></padding>
                
                <TextField fx:id="searchField" promptText="Filter by title or company..." 
                           style="-fx-padding: 8; -fx-background-radius: 5;" />
                
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <ListView fx:id="offersListView" prefWidth="350" style="-fx-background-radius: 5;" />
                    
                    <VBox fx:id="detailView" spacing="15" HBox.hgrow="ALWAYS" 
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;">
                        
                        <Label fx:id="detailTitle" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <Label fx:id="detailCompany" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" />
                        
                        <Separator />
                        
                        <Label text="Description:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <Label fx:id="detailDescription" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #34495e;" />
                        
                        <Label text="Requirements:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <Label fx:id="detailRequirements" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #34495e;" />
                        
                        <Region VBox.vgrow="ALWAYS" />
                        
                        <Button fx:id="applyButton" onAction="#handleApply" text="Apply Now" maxWidth="Infinity" 
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;" />
                    </VBox>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="My Applications">
            <VBox spacing="15">
                <padding><Insets top="15" /></padding>
                
                <TableView fx:id="applicationsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
                    <columns>
                        <TableColumn fx:id="colOfferTitle" prefWidth="450" text="Position" />
                        <TableColumn fx:id="colAppDate" prefWidth="150" text="App ID" />
                        <TableColumn fx:id="colStatus" prefWidth="150" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Refresh Status" onAction="#refreshApplications" 
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </Tab>
        
    </TabPane>
</VBox>