<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="700.0" prefWidth="1024.0" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.SupervisorController">
   <children>
      <VBox prefWidth="240.0" styleClass="sidebar" style="-fx-padding: 30;">
         <children>
            <Label text="ENSCS Portal" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
            <Label text="Supervisor Dashboard" textFill="#94a3b8" />
            <Separator prefWidth="200.0" style="-fx-padding: 20 0;" />
            <Button fx:id="btnManageOffers" onAction="#showOffersView" maxWidth="Infinity" styleClass="nav-button" text="📁 Manage Offers" />
            <Button fx:id="btnApplicants" onAction="#showApplicantsView" maxWidth="Infinity" styleClass="nav-button" text="👥 Applicants" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" maxWidth="Infinity" styleClass="btn-danger" text="Logout" style="-fx-padding: 10;" />
         </children>
      </VBox>
      <StackPane HBox.hgrow="ALWAYS" styleClass="main-bg">
         <children>
            <VBox fx:id="offersView" style="-fx-padding: 40;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="15">
                     <children>
                        <VBox>
                           <Label text="Internship Listings" styleClass="title-label" />
                           <Label text="View and manage current postings" styleClass="subtitle-label" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" prefWidth="220.0" promptText="Search listings..." />
                        <Button onAction="#showAddOfferDialog" styleClass="btn-primary" text="+ Create New" style="-fx-padding: 8 20;" />
                     </children>
                  </HBox>
                  <ListView fx:id="offersListView" VBox.vgrow="ALWAYS" style="-fx-margin: 20 0;" />
                  <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                     <Button onAction="#handleEditOffer" text="Edit Selected" styleClass="btn-secondary" />
                  </HBox>
               </children>
            </VBox>
            <VBox fx:id="applicantsView" visible="false" style="-fx-padding: 40;">
               <children>
                  <Label text="Incoming Applications" styleClass="title-label" />
                  <TableView fx:id="applicationsTable" VBox.vgrow="ALWAYS" style="-fx-margin: 20 0;">
                    <columns>
                      <TableColumn fx:id="colStudent" prefWidth="160" text="Student" />
                      <TableColumn fx:id="colOfferTitle" prefWidth="220" text="Position" />
                      <TableColumn fx:id="colDate" prefWidth="130" text="Date Applied" />
                      <TableColumn fx:id="colStatus" prefWidth="110" text="Status" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  </TableView>
                  <HBox spacing="15">
                     <Button onAction="#handleApprove" prefWidth="120" styleClass="btn-primary" text="Approve" />
                     <Button onAction="#handleReject" prefWidth="120" styleClass="btn-danger" text="Reject" />
                  </HBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</HBox>