<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<!--
  FIXES applied to post_offer_form.fxml:
  1. Removed the orphan <Button fx:id="applyButton" onAction="#handleApply"> that
     referenced a method which does not exist in PostOfferController. This caused a
     MethodNotFoundException at runtime.
  2. Added the missing <tagsField> TextField so Supervisor can enter comma-separated
     tags when using this form variant.
  3. Unified javafx version to 17 (was 8) to match post_offer.fxml and avoid
     duplicate-id issues when both files reference the same controller.
-->
<VBox spacing="15.0" prefWidth="500.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.enscs.internship.controllers.PostOfferController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Create New Internship Offer" />

    <GridPane vgap="15.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Job Title:"    GridPane.rowIndex="0" />
        <TextField fx:id="titleField" promptText="e.g. Cybersecurity Intern"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Company:"     GridPane.rowIndex="1" />
        <TextField fx:id="companyField" promptText="Enter company name"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Description:" GridPane.rowIndex="2" />
        <TextArea fx:id="descriptionArea" prefHeight="100.0"
                  promptText="Describe the role and responsibilities..."
                  wrapText="true"
                  GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Requirements:" GridPane.rowIndex="3" />
        <TextArea fx:id="requirementsArea" prefHeight="80.0"
                  promptText="One requirement per line"
                  GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <!-- FIX: tagsField was missing from this form variant -->
        <Label text="Tags:" GridPane.rowIndex="4" />
        <TextField fx:id="tagsField" promptText="e.g. Remote, Java, Security"
                   GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="submitButton" onAction="#handleSubmit" text="Post Offer"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 8 20;" />
    </HBox>
</VBox>
