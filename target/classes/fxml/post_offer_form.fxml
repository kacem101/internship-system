<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enscs.internship.controllers.PostOfferController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Create New Internship Offer" />
    
    <GridPane vgap="15.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Job Title:" GridPane.rowIndex="0" />
        <TextField fx:id="titleField" promptText="e.g. Cybersecurity Intern" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Company:" GridPane.rowIndex="1" />
        <TextField fx:id="companyField" promptText="Enter company name" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Description:" GridPane.rowIndex="2" />
        <TextArea fx:id="descriptionArea" prefHeight="100.0" promptText="Describe the role and responsibilities..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Requirements:" GridPane.rowIndex="3" />
        <TextArea fx:id="requirementsArea" prefHeight="80.0" promptText="Enter each requirement on a new line" GridPane.columnIndex="1" GridPane.rowIndex="3" />
    </GridPane>
    
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="submitButton" onAction="#handleSubmit" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Post Offer" />
    </HBox>
</VBox>