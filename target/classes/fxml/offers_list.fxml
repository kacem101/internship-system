<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" styleClass="main-bg" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.enscs.internship.controllers.OfferListController">
    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>

    <Label styleClass="title-label" text="Available Internship Offers" />

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleCol" prefWidth="280.0" text="Position Title" />
            <TableColumn fx:id="companyCol" prefWidth="200.0" text="Company" />
            <TableColumn fx:id="statusCol" prefWidth="100.0" text="Status" />
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleApply" text="Apply Now" styleClass="btn-secondary" style="-fx-padding: 10 30;" />
    </HBox>
</VBox>