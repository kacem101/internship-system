<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enscs.internship.controllers.StudentController">
   <children>
      <VBox prefWidth="200.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
         <children>
            <Label text="NSCS Portal" textFill="WHITE">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Separator prefWidth="200.0" style="-fx-padding: 10 0;" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent;" text="Browse Offers" textFill="WHITE" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent;" text="My Applications" textFill="WHITE" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #e74c3c;" text="Logout" textFill="WHITE" />
         </children>
      </VBox>

      <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 30; -fx-background-color: #ecf0f1;">
         <children>
            <Label fx:id="welcomeLabel" text="Welcome, Student!">
               <font><Font size="24.0" /></font>
            </Label>
            <TableView fx:id="offersTable" VBox.vgrow="ALWAYS" style="-fx-margin-top: 20;">
              <columns>
                <TableColumn fx:id="colTitle" text="Position" prefWidth="200"/>
                <TableColumn fx:id="colCompany" text="Company" prefWidth="150"/>
                <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="100"/>
              </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
               <Button onAction="#handleApply" style="-fx-background-color: #27ae60;" text="Apply to Selected" textFill="WHITE" />
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>