<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="15.0" styleClass="main-bg" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.RegisterController">
    <padding><Insets bottom="30.0" left="50.0" right="50.0" top="30.0" /></padding>

    <Label styleClass="title-label" text="Create ENSCS Account" />
    <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 13px;" wrapText="true" maxWidth="450.0" />

    <GridPane vgap="12.0" hgap="12.0" maxWidth="480.0" styleClass="card" style="-fx-padding: 25;">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <TextField fx:id="firstNameField" promptText="First Name" prefHeight="40" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="lastNameField"  promptText="Last Name" prefHeight="40" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="usernameField" promptText="Username" prefHeight="40" GridPane.columnSpan="2" GridPane.rowIndex="1"/>
        <TextField fx:id="emailField"    promptText="Email (e.g. name@enscs.dz)" prefHeight="40" GridPane.columnSpan="2" GridPane.rowIndex="2"/>
        <PasswordField fx:id="passwordField" promptText="Password" prefHeight="40" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" prefHeight="40" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <ComboBox fx:id="roleComboBox" promptText="I am a…" maxWidth="Infinity" prefHeight="40" GridPane.columnSpan="2" GridPane.rowIndex="4">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Student" />
                    <String fx:value="Supervisor" />
                </FXCollections>
            </items>
        </ComboBox>
        <TextField fx:id="extraInfoField" promptText="Major / Company Name" prefHeight="40" GridPane.columnSpan="2" GridPane.rowIndex="5"/>
    </GridPane>

    <Button onAction="#handleRegister" prefWidth="480.0" styleClass="btn-primary" style="-fx-padding: 12;" text="Sign Up" />
    <Hyperlink onAction="#goToLogin" text="Already have an account? Login here" style="-fx-text-fill: #3b82f6;" />
</VBox>