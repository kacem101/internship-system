<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" prefWidth="480.0" styleClass="main-bg" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.PostOfferController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    
    <Label text="Post New Internship Offer" styleClass="title-label" />
    <Separator />

    <VBox spacing="15.0" styleClass="card" style="-fx-padding: 20;">
        <VBox spacing="5.0">
            <Label text="Offer Title" styleClass="subtitle-label" />
            <TextField fx:id="titleField" promptText="e.g. Java Backend Intern" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Company" styleClass="subtitle-label" />
            <TextField fx:id="companyField" editable="false" style="-fx-background-color: #f1f5f9;" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Description" styleClass="subtitle-label" />
            <TextArea fx:id="descriptionArea" prefHeight="120.0" wrapText="true" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Requirements (Comma separated)" styleClass="subtitle-label" />
            <TextArea fx:id="requirementsArea" prefHeight="100.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Tags" styleClass="subtitle-label" />
            <TextField fx:id="tagsField" promptText="e.g. Remote, Java, Security" />
        </VBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Button onAction="#handleCancel" text="Cancel" styleClass="btn-danger" style="-fx-background-color: #94a3b8;"/>
        <Button fx:id="submitButton" onAction="#handleSubmit" text="Post Offer" styleClass="btn-primary" style="-fx-padding: 10 25;" />
    </HBox>
</VBox>