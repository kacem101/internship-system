<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enscs.internship.controllers.DashboardController">
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-min-width: 200;">
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
            </padding>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="Welcome, User" />
            <Separator style="-fx-opacity: 0.3;" />
            
            <Button maxWidth="Infinity" onAction="#handleViewOffers" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="🔍 Browse Offers" />
            
            <Button fx:id="postOfferButton" maxWidth="Infinity" onAction="#handlePostOffer" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="➕ Post New Offer" />
            
            <Button maxWidth="Infinity" onAction="#handleViewApplications" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="📄 My Applications" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <Label style="-fx-text-fill: #7f8c8d;" text="Select an option from the sidebar to begin." />
        </StackPane>
    </center>
</BorderPane>