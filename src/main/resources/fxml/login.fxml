<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" styleClass="main-bg" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.LoginController">
    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
    
    <VBox alignment="CENTER" spacing="5.0">
        <Label styleClass="title-label" text="ENSCS Portal" />
        <Label styleClass="subtitle-label" text="Please login to your account" />
    </VBox>

    <VBox maxWidth="320.0" spacing="12.0" styleClass="card" style="-fx-padding: 30;">
        <TextField fx:id="usernameField" promptText="Username" />
        <PasswordField fx:id="passwordField" promptText="Password" />
        <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 13px;" wrapText="true" />
        <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="btn-secondary" style="-fx-padding: 12;" text="Login" />
        <HBox alignment="CENTER" spacing="5">
            <Label text="New here?" styleClass="subtitle-label" />
            <Hyperlink text="Create an account" onAction="#handleGoToRegister" style="-fx-text-fill: #3b82f6;" />
        </HBox>
    </VBox>
</VBox>