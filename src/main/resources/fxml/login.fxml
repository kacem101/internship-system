<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.enscs.internship.controllers.LoginController" style="-fx-background-color: #2c3e50;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="ENSCS Internship System" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>
    
    <Button text="Login" onAction="#handleLogin" maxWidth="250" 
            style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;"/>
</VBox>