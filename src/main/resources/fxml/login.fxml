<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enscs.internship.controllers.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    
    <VBox alignment="CENTER" spacing="5.0">
        <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="ENSCS Portal" />
        <Label style="-fx-text-fill: #7f8c8d;" text="Please login to your account" />
    </VBox>

    <VBox maxWidth="300.0" spacing="10.0">
        <TextField fx:id="usernameField" promptText="Username" style="-fx-padding: 10;" />
        <PasswordField fx:id="passwordField" promptText="Password" style="-fx-padding: 10;" />
        <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true" />
        <Button maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10; -fx-font-weight: bold;" text="Login" />
    </VBox>
    <HBox alignment="CENTER" spacing="5">
    <Label text="New here?" />
    <Hyperlink text="Create an account" onAction="#handleGoToRegister" />
    </HBox>
</VBox>